# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=chatbot
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/chatbot

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=lead_conversations

# MinIO Configuration
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=admin123456
MINIO_BUCKET_NAME=chatbot-files
MINIO_USE_SSL=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Bitrix24 Configuration
BITRIX24_DOMAIN=your-company.bitrix24.com
BITRIX24_WEBHOOK_TOKEN=your_webhook_token_here
BITRIX24_CLIENT_ID=your_client_id
BITRIX24_CLIENT_SECRET=your_client_secret

# 3CX Configuration (For future use)
# 3CX_API_URL=https://your-3cx-server.com
# 3CX_API_KEY=your_3cx_api_key
# 3CX_ENABLED=false

# Embedding Configuration
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# MCP Configuration
MCP_SERVERS_ENABLED=true
