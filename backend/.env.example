# Backend Application Configuration

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=chatbot
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/chatbot

# Qdrant Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=lead_conversations

# MinIO Object Storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=admin123456
MINIO_BUCKET_NAME=chatbot-files
MINIO_USE_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# AI API Keys (REQUIRED - Get from providers)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# JWT Configuration
JWT_SECRET=your_secure_random_jwt_secret_here
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Bitrix24 Configuration
BITRIX24_DOMAIN=your-company.bitrix24.com
BITRIX24_WEBHOOK_TOKEN=your_webhook_token_here
BITRIX24_CLIENT_ID=
BITRIX24_CLIENT_SECRET=

# 3CX Configuration (Future)
# 3CX_API_URL=
# 3CX_API_KEY=
# 3CX_ENABLED=false

# Embedding Configuration
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# MCP Configuration
MCP_SERVERS_ENABLED=true

# ============================================
# Session Summary & Cleanup Configuration
# ============================================

# Enable automatic session summarization
ENABLE_SESSION_SUMMARY=true

# Hours of inactivity before considering session ended
# Default: 2 hours (production)
# For testing: 0.0167 (1 minute) or 0.05 (3 minutes)
# Change this to adjust when conversations are considered "finished"
SESSION_INACTIVITY_HOURS=2

# Cron schedule for summarization job
# Default: */30 * * * * (every 30 minutes in production)
# For testing: * * * * * (every minute)
# Format: minute hour day month weekday
# Examples:
#   * * * * * = Every minute (testing)
#   */30 * * * * = Every 30 minutes
#   */15 * * * * = Every 15 minutes
#   0 * * * * = Every hour
SUMMARY_CRON_INTERVAL=*/30 * * * *

# Minimum messages required to generate summary
# Sessions with fewer messages will be skipped
SUMMARY_MIN_MESSAGES=2

# Enable automatic cleanup of old messages
ENABLE_MESSAGE_CLEANUP=true

# Days to keep messages after summary is generated
# Default: 30 days
# After this period, individual messages are deleted but summaries remain
# Change this to adjust retention period (e.g., 7, 30, 60, 90 days)
CLEANUP_AFTER_DAYS=30

# Cron schedule for cleanup job
# Default: 0 2 * * * (daily at 2 AM)
# Examples:
#   0 2 * * * = Daily at 2 AM
#   0 3 * * 0 = Weekly on Sunday at 3 AM
#   0 4 1 * * = Monthly on 1st at 4 AM
CLEANUP_CRON_SCHEDULE=0 2 * * *
